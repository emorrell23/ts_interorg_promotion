          false}},{"id": "07cf0281-2d83-4f92-96fe-b651ecf657e0","properties": {"axisType": "X","linkedColumns": ["User Feedback
          Rating"]}}],"seriesColors": [{"serieName": "Conversations","color": "#FCC838"},{"serieName": "10/24/2024","color":
          "#2E75F0"},{"serieName": "up_vote","color": "#56D3A8"},{"serieName": "down_vote","color": "#f36775"}],"systemSeriesColors":
