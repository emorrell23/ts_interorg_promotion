liveboard:
  name: Spotter Conversations
  visualizations:
  - id: Viz_1
    answer:
      name: Feedback Response
      description: Excludes conversations without any feedback
      tables:
      - id: 'TS: Spotter Analytics'
        name: 'TS: Spotter Analytics'
      search_query: '[Conversations] [User Feedback Rating] [User Feedback Rating] = [User Feedback Rating].up_vote [User
        Feedback Rating].down_vote'
      answer_columns:
      - name: Conversations
        format:
          category: NUMBER
          numberFormatConfig:
            unit: AUTO
            decimals: 0.0
            negativeValueFormat: PREFIX_DASH
            toSeparateThousands: true
          isCategoryEditable: true
      - name: User Feedback Rating
      table:
        table_columns:
        - column_id: Conversations
          show_headline: false
        - column_id: User Feedback Rating
          show_headline: false
        ordered_column_ids:
        - User Feedback Rating
        - Conversations
        client_state: ''
        client_state_v2: '{"tableVizPropVersion": "V1"}'
      chart:
        type: PIE
        chart_columns:
        - column_id: Conversations
        - column_id: User Feedback Rating
        axis_configs:
        - x:
          - User Feedback Rating
          y:
          - Conversations
        client_state: ''
        client_state_v2: '{"version": "V4DOT2","chartProperties": {"responsiveLayoutPreference": "AUTO_ON","chartSpecific":
          {"customProps": "{\"showLabel\":true,\"showComparison\":true,\"showSparkline\":true,\"showAnomalies\":false,\"showBounds\":true,\"customCompare\":\"PREV_AVAILABLE\"}","pivotSummariesState":
