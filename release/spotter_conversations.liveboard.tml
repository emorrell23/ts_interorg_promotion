  - id: Viz_4
    viz_guid: 33e0af36-5f86-4689-8a47-d6d955b98935
    note_tile:
      html_parsed_string: '<h2 class="theme-module__editor-h2" dir="ltr"><span style="white-space: pre-wrap;">Track the entire
        conversation journey of your users on Spotter from Liveboards </span></h2><ul class="theme-module__editor-ul"><li
        value="1" class="theme-module__editor-list-item"><span style="white-space: pre-wrap;">- Analyze engagement by viewing
        exact questions, search tokens, and queries with feedback. </span></li><li value="2" class="theme-module__editor-list-item"><span
        style="white-space: pre-wrap;">- Track edits, deletions, and other key events. </span></li><li value="3" class="theme-module__editor-list-item"><span
        style="white-space: pre-wrap;">- Expand insights by adding columns and drilling into rows.</span></li></ul><p class="theme-module__editor-paragraph"
        dir="ltr"><b><strong class="theme-module__editor-text-bold" style="white-space: pre-wrap;">Note</strong></b><span
        style="white-space: pre-wrap;">: </span><span style="color: rgb(240, 65, 82); white-space: pre-wrap;">There is a delay
        of up to two hours from the time an event is triggered for it to appear on this Liveboard.</span></p><p class="theme-module__editor-paragraph"
        dir="ltr"><br></p><div class="pinboard-note-tile-module__noteTileBg editor-module__bgNode" style="background-color:
        rgb(255, 255, 255);"></div><p class="theme-module__editor-paragraph" dir="ltr"><br></p>'
  - id: Viz_5
    answer:
      name: Conversations by Model
      description: Top 5 models which have the most conversations
      tables:
      - id: 'TS: Spotter Analytics'
        name: 'TS: Spotter Analytics'
      search_query: '[Model] [Conversations] sort by [Conversations] descending top 5 [Model] != ''{null}'''
      answer_columns:
      - name: Conversations
      - name: Model
      table:
        table_columns:
        - column_id: Conversations
          show_headline: false
        - column_id: Model
          show_headline: false
        ordered_column_ids:
        - Model
        - Conversations
        client_state: ''
        client_state_v2: '{"tableVizPropVersion": "V1","columnProperties": [{"columnId": "Model","columnProperty": {}},{"columnId":
          "Conversations","columnProperty": {}}]}'
      chart:
        type: BAR
        chart_columns:
        - column_id: Conversations
        - column_id: Model
        axis_configs:
        - x:
          - Model
          y:
          - Conversations
        client_state: ''
        client_state_v2: '{"version": "V4DOT2","chartProperties": {"responsiveLayoutPreference": "AUTO_ON","chartSpecific":
