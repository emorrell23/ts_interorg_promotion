  - id: Viz_5
    answer:
      name: Hourly Active Query Users
      description: Per Day of Week in Filtered Range
      tables:
      - id: 'TS: AI and BI Stats'
        name: 'TS: AI and BI Stats'
        obj_id: TSAIandBIStats-8ca8f010
      search_query: unique count [User ID] by [TS Query Start Time].'day of week' by [TS Query Start Time].'hour of day' sort
        by [TS Query Start Time] [TS Query Start Time].'day of week' descending
      answer_columns:
      - name: Day of Week(TS Query Start Time)
        sort_info:
          category: DEFAULT
      - name: HOUR_OF_DAY(TS Query Start Time)
      - name: Unique Number of User ID
      table:
        table_columns:
        - column_id: Day of Week(TS Query Start Time)
          show_headline: false
        - column_id: HOUR_OF_DAY(TS Query Start Time)
          show_headline: false
        - column_id: Unique Number of User ID
          show_headline: false
        ordered_column_ids:
        - Day of Week(TS Query Start Time)
        - HOUR_OF_DAY(TS Query Start Time)
        - Unique Number of User ID
        client_state: ''
        client_state_v2: '{"tableVizPropVersion": "V1"}'
      chart:
        type: STACKED_AREA
        chart_columns:
        - column_id: Day of Week(TS Query Start Time)
        - column_id: HOUR_OF_DAY(TS Query Start Time)
        - column_id: Unique Number of User ID
        axis_configs:
        - x:
          - HOUR_OF_DAY(TS Query Start Time)
          y:
          - Unique Number of User ID
          color:
          - Day of Week(TS Query Start Time)
        client_state: ''
        client_state_v2: '{"version": "V4DOT2","chartProperties": {"responsiveLayoutPreference": "AUTO_ON","chartSpecific":
          {"pivotSummariesState": {}},"showStackedLabels": false,"allLabels": false,"legendPosition": "TOP_LEGEND"},"columnProperties":
          [{"columnId": "Day of Week(TS Query Start Time)","columnProperty": {}},{"columnId": "HOUR_OF_DAY(TS Query Start
