  - id: Viz_18
    viz_guid: 44955038-f0e2-467b-88f7-95cd5990bb7e
    note_tile:
      html_parsed_string: '<h2 class="theme-module__editor-h2-spaced" dir="ltr"><u><span class="theme-module__editor-text-underline"
        style="white-space: pre-wrap;">Known Limitations</span></u></h2><p class="theme-module__editor-paragraph-spaced" dir="ltr"><br></p><p
        class="theme-module__editor-paragraph-spaced" dir="ltr" style="text-align: start;"><b><strong class="theme-module__editor-text-bold"
        style="font-weight: 700; white-space: pre-wrap;">1/ </strong></b><i><b><strong class="theme-module__editor-text-bold
        theme-module__editor-text-italic" style="font-weight: 700; white-space: pre-wrap;">The liveboard does not report deprecated
        objects and API usage. This will be included in the later versions.</strong></b></i></p><p class="theme-module__editor-paragraph-spaced"
        dir="ltr" style="text-align: start;"><b><strong class="theme-module__editor-text-bold" style="font-weight: 700; white-space:
        pre-wrap;">2/ </strong></b><i><b><strong class="theme-module__editor-text-bold theme-module__editor-text-italic" style="font-weight:
        700; white-space: pre-wrap;">The liveboard reports active users based on query consumption alone</strong></b></i></p><p
        class="theme-module__editor-paragraph-spaced"><br></p><h2 class="theme-module__editor-h2-spaced" dir="ltr"><u><span
        class="theme-module__editor-text-underline" style="white-space: pre-wrap;">Data Sources</span></u></h2><p class="theme-module__editor-paragraph-spaced"
        dir="ltr"><br></p><p class="theme-module__editor-paragraph-spaced" dir="ltr"><b><strong class="theme-module__editor-text-bold"
        style="font-weight: 700; white-space: pre-wrap;">1/ Querystats</strong></b><span style="white-space: pre-wrap;"> </span></p><p
        class="theme-module__editor-paragraph-spaced" dir="ltr"><i><em class="theme-module__editor-text-italic" style="white-space:
        pre-wrap;">Contains data related to billable query consumption for customers on the query-based consumption pricing
        model.</em></i></p><p class="theme-module__editor-paragraph-spaced" dir="ltr"><b><strong class="theme-module__editor-text-bold"
        style="font-weight: 700; white-space: pre-wrap;">2/ Atlas</strong></b><span style="white-space: pre-wrap;"> </span></p><p
        class="theme-module__editor-paragraph-spaced" dir="ltr"><i><em class="theme-module__editor-text-italic" style="white-space:
        pre-wrap;">Contains data related to metadata information for customers on the query-based consumption pricing model.</em></i></p><p
        class="theme-module__editor-paragraph-spaced" dir="ltr" style="text-align: start;"><b><strong class="theme-module__editor-text-bold"
        style="font-weight: 700; white-space: pre-wrap;">3/ ThoughtSpot Dependencies</strong></b><span style="white-space:
        pre-wrap;"> </span></p><p class="theme-module__editor-paragraph-spaced" dir="ltr" style="text-align: start;"><i><em
        class="theme-module__editor-text-italic" style="white-space: pre-wrap;">Objects which are can be created from Worksheets
        are considered as dependencies. (primarily these are Liveboards and Answers)</em></i></p><p class="theme-module__editor-paragraph-spaced"
        dir="ltr"><br></p><p class="theme-module__editor-paragraph-spaced" dir="ltr"><br></p><div class="pinboard-note-tile-module__noteTileBg
        editor-module__bgNode" style="background-color: rgb(255, 255, 255);"></div>'
