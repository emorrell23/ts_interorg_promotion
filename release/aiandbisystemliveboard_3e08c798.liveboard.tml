  - id: Viz_9
    answer:
      name: Top 10 User Champions
      tables:
      - id: 'TS: AI and BI Stats'
        name: 'TS: AI and BI Stats'
        obj_id: TSAIandBIStats-8ca8f010
      formulas:
      - id: formula_Leaderboard Rank
        name: Leaderboard Rank
        expr: rank ( [formula_Leaderboard Score] , 'desc' )
        properties:
          column_type: ATTRIBUTE
        was_auto_generated: false
      - id: formula_Leaderboard Score
        name: Leaderboard Score
        expr: 0 + ( [formula_Searches (5x)] * 5 ) + ( [formula_Answers (3x)] * 3 ) + ( [formula_Liveboards (1x)] * 1 ) + (
          [formula_Data exports (-5x)] * - 5 ) + ( [formula_Spotter (6x)] * 6 ) + ( [formula_Drill Down (2x)] * 2 ) + ( [formula_KPI
          Monitor (2x)] * 2 )
        was_auto_generated: false
      - id: formula_Answers (3x)
        name: Answers (3x)
        expr: unique_count_if ( [Object Type] = 'answer' , [ThoughtSpot Query ID] )
        was_auto_generated: false
      - id: formula_Data exports (-5x)
        name: Data exports (-5x)
        expr: unique_count_if ( [User Action] = 'download' , [ThoughtSpot Query ID] )
        was_auto_generated: false
      - id: formula_Drill Down (2x)
        name: Drill Down (2x)
        expr: unique_count_if ( [User Action] = 'drill_down' , [ThoughtSpot Query ID] )
        was_auto_generated: false
      - id: formula_KPI Monitor (2x)
        name: KPI Monitor (2x)
        expr: unique_count_if ( [User Action] = 'kpi_monitor' , [ThoughtSpot Query ID] )
        was_auto_generated: false
      - id: formula_Liveboards (1x)
        name: Liveboards (1x)
        expr: unique_count_if ( [Object Type] = 'liveboard' , [ThoughtSpot Query ID] )
        was_auto_generated: false
      - id: formula_Searches (5x)
        name: Searches (5x)
        expr: unique_count_if ( [User Action] = 'search_data' , [ThoughtSpot Query ID] )
        was_auto_generated: false
      - id: formula_Spotter (6x)
        name: Spotter (6x)
        expr: unique_count_if ( [User Action] = 'spotter' , [ThoughtSpot Query ID] )
        was_auto_generated: false
      search_query: '[User] top 10 [formula_Leaderboard Score] [User] != [User].{empty} [User].{null}'
      answer_columns:
      - name: Leaderboard Score
      - name: User
      table:
        table_columns:
        - column_id: Leaderboard Score
          show_headline: false
        - column_id: User
          show_headline: false
        ordered_column_ids:
        - User
        - Leaderboard Score
        client_state: ''
        client_state_v2: '{"tableVizPropVersion": "V1","orderedColumnIds": ["User"]}'
      chart:
        type: BAR
        chart_columns:
        - column_id: Leaderboard Score
        - column_id: User
        axis_configs:
        - x:
          - User
          y:
          - Leaderboard Score
        client_state: ''
        client_state_v2: '{"version": "V4DOT2","chartProperties": {"responsiveLayoutPreference": "AUTO_ON","chartSpecific":
          {"pivotSummariesState": {}},"showStackedLabels": true,"allLabels": true},"columnProperties": [{"columnId": "User","columnProperty":
          {}},{"columnId": "Leaderboard Score","columnProperty": {"dataLabels": true}}],"axisProperties": [{"id": "58fc45b1-e798-47d0-b369-95ff1d9977ab","properties":
          {"axisType": "Y","linkedColumns": ["Leaderboard Score"],"isOpposite": false}},{"id": "91f2ef6a-9855-4e51-81cb-bd7e87bd190d","properties":
          {"axisType": "X","linkedColumns": ["User"]}}],"seriesColors": [{"serieName": "0717f82b-d46a-4bde-ac41-2c025ce80948","color":
          "#747E8C"},{"serieName": "7e9e873d-7491-4e89-abc7-499952952b46","color": "#FCC838"},{"serieName": "c73ba3db-7b98-4ee2-9e7c-4b9b65552a37","color":
          "#48D1E0"},{"serieName": "f11301b7-373a-4ab1-abb1-08a3d90236c3","color": "#2E75F0"},{"serieName": "Leaderboard Score","color":
          "#56D3A8"}],"systemSeriesColors": [{"serieName": "0717f82b-d46a-4bde-ac41-2c025ce80948","color": "#747E8C"},{"serieName":
          "7e9e873d-7491-4e89-abc7-499952952b46","color": "#FCC838"},{"serieName": "c73ba3db-7b98-4ee2-9e7c-4b9b65552a37","color":
          "#48D1E0"},{"serieName": "f11301b7-373a-4ab1-abb1-08a3d90236c3","color": "#2E75F0"},{"serieName": "Leaderboard Score","color":
          "#06BF7F"}]}'
