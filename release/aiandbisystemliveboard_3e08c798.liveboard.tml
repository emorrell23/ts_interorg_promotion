  - id: Viz_12
    answer:
      name: User Time Saved in Hours
      description: Time Saved is defined as the Number of Activities *  Time Saved per Activity (adjust using the parameter
        above)
      tables:
      - id: 'TS: AI and BI Stats'
        name: 'TS: AI and BI Stats'
        obj_id: TSAIandBIStats-8ca8f010
      formulas:
      - id: formula_Hours Saved
        name: Hours Saved
        expr: ( [formula_Billable Queries] * ifnull ( [Time Saved per activity ( in mins )] , 10 ) ) / 60
        was_auto_generated: false
      - id: formula_Billable Queries
        name: Billable Queries
        expr: unique_count_if ( [Is Billable] , [ThoughtSpot Query ID] )
        was_auto_generated: false
      search_query: '[formula_Billable Queries] [TS Query Start Time] [TS Query Start Time].''last 6 months'' [TS Query Start
        Time].monthly [formula_Hours Saved] [User Action] [User Action].drill_down [User Action].explore [User Action].search_data
        [User Action].spotiq_auto_analyze [User Action].spotter'
      answer_columns:
      - name: Billable Queries
        custom_name: Number of Activities
        dynamic_title: Number of Activities
      - name: Hours Saved
      - name: Month(TS Query Start Time)
      - name: User Action
      table:
        table_columns:
        - column_id: Billable Queries
          show_headline: false
        - column_id: Hours Saved
          show_headline: false
        - column_id: Month(TS Query Start Time)
          show_headline: false
        - column_id: User Action
          show_headline: false
        ordered_column_ids:
        - Month(TS Query Start Time)
        - User Action
        - Billable Queries
        - Hours Saved
        client_state: ''
        client_state_v2: '{"tableVizPropVersion": "V1","columnProperties": [{"columnId": "Billable Queries","columnProperty":
          {}}]}'
      chart:
        type: STACKED_COLUMN
        chart_columns:
        - column_id: Billable Queries
        - column_id: Hours Saved
        - column_id: Month(TS Query Start Time)
        - column_id: User Action
        axis_configs:
        - x:
          - Month(TS Query Start Time)
          y:
          - Hours Saved
          color:
          - User Action
        client_state: ''
        client_state_v2: '{"version": "V4DOT2","chartProperties": {"gridLines": {},"responsiveLayoutPreference": "USER_PREFERRED_ON","chartSpecific":
          {"customProps": "{\"advancedProperties\":{\"tooltip\":{\"enabled\":true}}}","dataFieldArea": "column"},"showStackedLabels":
          true,"allLabels": true,"legendPosition": "TOP_LEGEND"},"columnProperties": [{"columnId": "Billable Queries","columnProperty":
          {}},{"columnId": "Month(TS Query Start Time)","columnProperty": {}},{"columnId": "User Action","columnProperty":
          {}},{"columnId": "Hours Saved","columnProperty": {"dataLabels": true}}],"axisProperties": [{"id": "4e996580-62a6-4acb-b770-ff8cc7bf7321","properties":
          {"axisType": "Y","linkedColumns": ["Hours Saved"],"isOpposite": false}},{"id": "565c5310-0c35-4629-85d0-bf627fd98d6e","properties":
          {"axisType": "X","linkedColumns": ["Month(TS Query Start Time)"]}}],"systemSeriesColors": [{"serieName": "explore","color":
          "#48D1E0"},{"serieName": "search_data","color": "#2E75F0"},{"serieName": "drill_down","color": "#06BF7F"},{"serieName":
          "spotter","color": "#FCC838"}],"tooltipConfig": {"columnIds": ["User Action","Month(TS Query Start Time)","Billable
          Queries","Hours Saved"]}}'
