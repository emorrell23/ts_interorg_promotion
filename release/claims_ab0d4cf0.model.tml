  - name: OFac
    formula_id: formula_OFac
    properties:
      column_type: ATTRIBUTE
      index_type: DONT_INDEX
  - name: Claimant First And Last Name
    formula_id: formula_Claimant First And Last Name
    properties:
      column_type: ATTRIBUTE
      index_type: DONT_INDEX
  - name: Injury Location
