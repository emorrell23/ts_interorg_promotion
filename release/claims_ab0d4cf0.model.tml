obj_id: Claims-ab0d4cf0
model:
  name: Claims - Payments
  description: Star schema for Claims reporting that use the Fact Claim Payment fact table only. Also contains associated
    dimensions. Used for a majority of claims reporting.
  model_tables:
  - name: FACT_CLAIM_PAYMENT
    joins:
    - with: DIM_ADDRESS_BOOK_PAYEE_CALC_ONLY
      'on': '[FACT_CLAIM_PAYMENT::ENTITY_ID] = [DIM_ADDRESS_BOOK::ADDRESS_BOOK_ID]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_BANK_ACCOUNT
      'on': '[FACT_CLAIM_PAYMENT::BANK_ACCOUNT_KEY] = [DIM_BANK_ACCOUNT::BANK_ACCOUNT_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_CLAIMANT_CURRENT
      'on': '[FACT_CLAIM_PAYMENT::CLAIMANT_SCD2_KEY] = [DIM_CLAIMANT_CURRENT::CLAIMANT_SCD2_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_CLAIM_CURRENT
      'on': '[FACT_CLAIM_PAYMENT::CLAIM_SCD2_KEY] = [DIM_CLAIM_CURRENT::CLAIM_SCD2_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_INSURED_PAYEE_CALC_ONLY
      'on': '[FACT_CLAIM_PAYMENT::ENTITY_ID] = [DIM_INSURED::INSURED_ID]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_INSURER_PAYEE_CALC_ONLY
      'on': '[FACT_CLAIM_PAYMENT::ENTITY_ID] = [DIM_INSURER::INSURER_ID]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_LINE_OF_BUSINESS
      'on': '[FACT_CLAIM_PAYMENT::LINE_OF_BUSINESS_KEY] = [DIM_LINE_OF_BUSINESS::LINE_OF_BUSINESS_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_PAYEE
      'on': '[FACT_CLAIM_PAYMENT::CLAIM_PAYMENT_KEY] = [DIM_PAYEE::PAYMENT_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_PAYMENT_METHOD
      'on': '[FACT_CLAIM_PAYMENT::PAYMENT_METHOD_KEY] = [DIM_PAYMENT_METHOD::PAYMENT_METHOD_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_PAYMENT_TYPE
      'on': '[FACT_CLAIM_PAYMENT::PAYMENT_TYPE_KEY] = [DIM_PAYMENT_TYPE::PAYMENT_TYPE_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_POLICY
      'on': '[FACT_CLAIM_PAYMENT::POLICY_KEY] = [DIM_POLICY::POLICY_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    - with: DIM_RESERVE_TYPE
      'on': '[FACT_CLAIM_PAYMENT::RESERVE_TYPE_KEY] = [DIM_RESERVE_TYPE::RESERVE_TYPE_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    obj_id: FACT_CLAIM_PAYMENT-df2767a3
  - name: DIM_CLAIMANT_CURRENT
    obj_id: DIM_CLAIMANT_CURRENT-9a0aed7a
  - name: DIM_PAYMENT_TYPE
    obj_id: DIM_PAYMENT_TYPE-5e7a6930
  - name: DIM_POLICY
    obj_id: DIM_POLICY-a0674bf4
  - name: DIM_BANK_ACCOUNT
    obj_id: DIM_BANK_ACCOUNT-f1ae14ff
  - name: DIM_INSURED
    alias: DIM_INSURED_PAYEE_CALC_ONLY
    obj_id: DIM_INSURED-3935196b
  - name: DIM_INSURER
    alias: DIM_INSURER_PAYEE_CALC_ONLY
    obj_id: DIM_INSURER-7deb435f
  - name: DIM_ADDRESS_BOOK
    alias: DIM_ADDRESS_BOOK_PAYEE_CALC_ONLY
    obj_id: DIM_ADDRESS_BOOK-a3777fc9
  - name: DIM_LINE_OF_BUSINESS
    obj_id: DIM_LINE_OF_BUSINESS-98dd8f2d
  - name: DIM_CLAIM_CURRENT
    joins:
    - with: DIM_USER
      'on': '[DIM_CLAIM_CURRENT::EXAMINER_USER_KEY] = [DIM_USER::USER_KEY]'
      type: LEFT_OUTER
      cardinality: MANY_TO_ONE
    obj_id: DIM_CLAIM_CURRENT-ab704eb1
  - name: DIM_PAYMENT_METHOD
    obj_id: DIM_PAYMENT_METHOD-e1ebbdc5
  - name: DIM_RESERVE_TYPE
    obj_id: DIM_RESERVE_TYPE-2cb573b7
  - name: DIM_PAYEE
    obj_id: DIM_PAYEE-5e745b44
  - name: DIM_USER
    obj_id: DIM_USER-d00f59dd
  formulas:
  - id: 'formula_Claim #'
    name: 'Claim #'
    expr: if ( count ( [formula_Payee] ) > 1 and max ( if ( [FACT_CLAIM_PAYMENT::PAYEE_TYPE_CODE] = "C" ) then 1 else 0 )
      = 1 ) then "Combined" else max ( [FACT_CLAIM_PAYMENT::CLAIM_NUMBER] )
  - id: formula_Claimant First And Last Name
    name: Claimant First And Last Name
    expr: if ( ( [DIM_CLAIMANT_CURRENT::FIRST_NAME] = [ClaimantFirstName] and [DIM_CLAIMANT_CURRENT::LAST_NAME] = [ClaimantLastName]
      ) or ( [ClaimantFirstName] = 'null' and [ClaimantLastName] = 'null' ) ) then true else false
  - id: formula_Good Payment
    name: Good Payment
    expr: ifnull ( ( not [DIM_PAYEE::IS_ADDRESS_INVALID] and not [DIM_PAYEE::IS_ACCOUNT_OVERDRAWN] and not [DIM_PAYEE::IS_RESERVES_EXCEEDED]
      and not [DIM_PAYEE::IS_BLOCKED_VENDOR] and not [DIM_PAYEE::IS_NO_ACCOUNT] and not [DIM_PAYEE::IS_CLAIM_VERIFICATION_BLOCK]
      and ifnull ( [DIM_PAYEE::FLAG_ACH] , '' ) = '' ) or ( not [DIM_PAYEE::IS_EMAIL_INVALID] and not [DIM_PAYEE::IS_PHONE_INVALID]
      ) , true )
  - id: formula_Injury Location
    name: Injury Location
    expr: concat ( [DIM_CLAIM_CURRENT::INJURY_ADDRESS1] , ' ' , if ( strlen ( [DIM_CLAIM_CURRENT::INJURY_ADDRESS2] ) > 0 )
      then [DIM_CLAIM_CURRENT::INJURY_ADDRESS2] else '' , ' ' , [DIM_CLAIM_CURRENT::INJURY_CITY] , ', ' , [DIM_CLAIM_CURRENT::INJURY_STATE]
      , ' ' , [DIM_CLAIM_CURRENT::INJURY_ZIP_CODE] )
  - id: formula_Insured Location
    name: Insured Location
    expr: concat ( [DIM_POLICY::INSURED_ADDRESS_1] , ' ' , [DIM_POLICY::INSURED_CITY] , ', ' , [DIM_POLICY::INSURED_STATE]
      , ' ' , [DIM_POLICY::INSURED_ZIP_CODE] )
  - id: formula_Is Jurisdiction CA
    name: Is Jurisdiction CA
    expr: if ( [DIM_CLAIM_CURRENT::JURISDICTION_CODE] = 'CA' ) then true else false
  - id: formula_OFac
    name: OFac
    expr: ifnull ( [DIM_PAYEE::IS_OFAC_MATCH] , false )
  - id: formula_Payee (Max)
    name: Payee (Max)
    expr: max ( [formula_Payee]  )
  - id: formula_Payee
    name: Payee
    expr: 'if ( [FACT_CLAIM_PAYMENT::PAYEE_TYPE_CODE] = "R" ) then [DIM_INSURER_PAYEE_CALC_ONLY::INSURER_NAME_1] else if (
      [FACT_CLAIM_PAYMENT::PAYEE_TYPE_CODE] = "D" ) then [DIM_POLICY::INSURED_NAME_1] else if ( [FACT_CLAIM_PAYMENT::PAYEE_TYPE_CODE]
      = "C" ) then [DIM_CLAIMANT_CURRENT::CLAIMANT_NAME] else [DIM_CLAIMANT_CURRENT::CLAIMANT_NAME] '
  - id: formula_Payment Count
    name: Payment Count
    expr: count ( [FACT_CLAIM_PAYMENT::PAYMENT_ID] )
  columns:
  - name: Claim ID
    column_id: DIM_CLAIM_CURRENT::CLAIM_ID
    properties:
      column_type: ATTRIBUTE
      index_type: DONT_INDEX
  - name: Payee
    formula_id: formula_Payee
    properties:
      column_type: ATTRIBUTE
      index_type: DONT_INDEX
  - name: Payee (Max)
    formula_id: formula_Payee (Max)
    properties:
      column_type: ATTRIBUTE
      index_type: DONT_INDEX
  - name: 'Claim #'
    formula_id: 'formula_Claim #'
    properties:
      column_type: ATTRIBUTE
      index_type: DONT_INDEX
  - name: Good Payment
